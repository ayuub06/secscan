<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Security Scan Report &#8212; {{ scan_result.scan_id[:8] }}</title>
<style>
/* ── Reset & base ─────────────────────────────────────────────────────── */
* { box-sizing: border-box; margin: 0; padding: 0; }
html, body {
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Helvetica, Arial, sans-serif;
    font-size: 14px;
    line-height: 1.6;
    color: #334155;
    background: #f1f5f9;
}

/* ── Header ───────────────────────────────────────────────────────────── */
.report-header {
    background: #0f172a;
    color: #ffffff;
    padding: 36px 48px 28px;
}
.header-top {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
}
.header-brand {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #64748b;
    margin-bottom: 8px;
}
.header-title {
    font-size: 28px;
    font-weight: 800;
    color: #f1f5f9;
}
.header-scan-id { text-align: right; }
.header-scan-id .label {
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: #475569;
    margin-bottom: 4px;
}
.header-scan-id .value {
    font-size: 12px;
    color: #94a3b8;
    font-family: "Courier New", Courier, monospace;
    word-break: break-all;
    max-width: 360px;
}
.header-sub {
    font-size: 12px;
    color: #475569;
    margin-top: 20px;
    padding-top: 16px;
    border-top: 1px solid #1e293b;
}

/* ── Content wrapper ──────────────────────────────────────────────────── */
.content {
    max-width: 960px;
    margin: 0 auto;
    padding: 32px 48px 48px;
}

/* ── Card ─────────────────────────────────────────────────────────────── */
.card {
    background: #ffffff;
    border: 1px solid #e2e8f0;
    border-radius: 8px;
    padding: 24px;
    margin-bottom: 24px;
}
.card-title {
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: #94a3b8;
    margin-bottom: 16px;
    padding-bottom: 12px;
    border-bottom: 1px solid #f1f5f9;
}

/* ── Scan info ────────────────────────────────────────────────────────── */
.info-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 20px;
}
.info-item { flex: 1; min-width: 180px; }
.info-label {
    font-size: 10px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #94a3b8;
    margin-bottom: 4px;
}
.info-value {
    font-size: 13px;
    color: #1e293b;
    font-weight: 500;
}
.info-value.mono {
    font-family: "Courier New", Courier, monospace;
    font-size: 12px;
    color: #334155;
}

/* ── Summary row ──────────────────────────────────────────────────────── */
.summary-row {
    display: flex;
    gap: 12px;
}
.sev-box {
    flex: 1;
    border-radius: 8px;
    padding: 18px 10px;
    text-align: center;
    color: #ffffff;
}
.sev-count {
    display: block;
    font-size: 34px;
    font-weight: 900;
    line-height: 1;
    margin-bottom: 6px;
}
.sev-label {
    display: block;
    font-size: 9px;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    opacity: 0.9;
}

/* ── Findings heading ─────────────────────────────────────────────────── */
.section-heading {
    font-size: 17px;
    font-weight: 700;
    color: #1e293b;
    margin: 8px 0 16px;
    display: flex;
    align-items: center;
    gap: 10px;
}
.total-badge {
    font-size: 12px;
    font-weight: 600;
    background: #e2e8f0;
    color: #475569;
    padding: 2px 10px;
    border-radius: 12px;
}
.no-findings {
    text-align: center;
    color: #94a3b8;
    font-size: 15px;
    padding: 48px 0;
    font-style: italic;
}

/* ── Finding card ─────────────────────────────────────────────────────── */
.finding-card {
    background: #ffffff;
    border: 1px solid #e2e8f0;
    border-left: 5px solid #94a3b8;
    border-radius: 8px;
    padding: 20px 24px;
    margin-bottom: 16px;
    page-break-inside: avoid;
}
.finding-header {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    margin-bottom: 16px;
}
.sev-badge {
    display: inline-block;
    padding: 3px 10px;
    border-radius: 4px;
    font-size: 10px;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: #ffffff;
    white-space: nowrap;
    flex-shrink: 0;
    margin-top: 3px;
}
.finding-title-block { flex: 1; }
.finding-title {
    font-size: 15px;
    font-weight: 700;
    color: #1e293b;
    line-height: 1.4;
}
.finding-target {
    font-size: 12px;
    color: #64748b;
    font-family: "Courier New", Courier, monospace;
    margin-top: 3px;
}

/* ── Field blocks ─────────────────────────────────────────────────────── */
.field-group { margin-bottom: 14px; }
.field-group:last-child { margin-bottom: 0; }
.field-label {
    font-size: 10px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #94a3b8;
    margin-bottom: 5px;
}
.field-text {
    font-size: 13px;
    color: #334155;
    line-height: 1.65;
}
.evidence-box {
    background: #f8fafc;
    border: 1px solid #cbd5e1;
    border-radius: 6px;
    padding: 12px 14px;
    font-family: "Courier New", Courier, monospace;
    font-size: 12px;
    color: #334155;
    line-height: 1.5;
    white-space: pre-wrap;
    word-break: break-all;
}
.remediation-box {
    background: #f0fdf4;
    border: 1px solid #bbf7d0;
    border-left: 4px solid #22c55e;
    border-radius: 6px;
    padding: 12px 14px;
    font-size: 13px;
    color: #166534;
    line-height: 1.65;
}

/* ── CVE tags ─────────────────────────────────────────────────────────── */
.cve-list { margin-top: 4px; }
.cve-tag {
    display: inline-block;
    background: #eff6ff;
    border: 1px solid #bfdbfe;
    color: #1d4ed8;
    font-size: 11px;
    font-weight: 600;
    padding: 2px 8px;
    border-radius: 4px;
    margin: 2px 4px 2px 0;
    font-family: "Courier New", Courier, monospace;
}

/* ── Footer ───────────────────────────────────────────────────────────── */
.report-footer {
    border-top: 1px solid #e2e8f0;
    margin-top: 48px;
    padding: 24px 0 8px;
    text-align: center;
}
.footer-disclaimer {
    font-size: 11px;
    color: #94a3b8;
    max-width: 660px;
    margin: 0 auto 10px;
    line-height: 1.7;
}
.footer-timestamp {
    font-size: 11px;
    color: #cbd5e1;
    font-family: "Courier New", Courier, monospace;
}
</style>
</head>
<body>

<!-- ── Header ─────────────────────────────────────────────────────────────── -->
<div class="report-header">
    <div class="header-top">
        <div>
            <div class="header-brand">secscan &middot; Automated Security Scanner</div>
            <div class="header-title">Security Scan Report</div>
        </div>
        <div class="header-scan-id">
            <div class="label">Scan ID</div>
            <div class="value">{{ scan_result.scan_id }}</div>
        </div>
    </div>
    <div class="header-sub">
        Report generated: {{ generated_at }}&nbsp;&nbsp;&bull;&nbsp;&nbsp;Authorized by: {{ scan_result.authorized_by }}
    </div>
</div>

<div class="content">

<!-- ── Scan details ───────────────────────────────────────────────────────── -->
<div class="card">
    <div class="card-title">Scan Details</div>
    <div class="info-grid">
        <div class="info-item">
            <div class="info-label">Target Scope</div>
            <div class="info-value mono">{{ scan_result.target_scope | join(", ") }}</div>
        </div>
        <div class="info-item">
            <div class="info-label">Authorized By</div>
            <div class="info-value">{{ scan_result.authorized_by }}</div>
        </div>
        <div class="info-item">
            <div class="info-label">Scan Started</div>
            <div class="info-value mono">{{ scan_result.started_at }}</div>
        </div>
        <div class="info-item">
            <div class="info-label">Scan Completed</div>
            <div class="info-value mono">{{ scan_result.completed_at or "&#8212;" }}</div>
        </div>
        <div class="info-item">
            <div class="info-label">Checks Run</div>
            <div class="info-value">{{ scan_result.checks_run | join(", ") or "none" }}</div>
        </div>
    </div>
</div>

<!-- ── Summary ────────────────────────────────────────────────────────────── -->
<div class="card">
    <div class="card-title">Findings Summary</div>
    <div class="summary-row">
        {% for sev_name, sev_key in [("CRITICAL", "critical"), ("HIGH", "high"), ("MEDIUM", "medium"), ("LOW", "low"), ("INFO", "info")] %}
        <div class="sev-box" style="background: {{ severity_colors[sev_name] }};">
            <span class="sev-count">{{ summary[sev_key] }}</span>
            <span class="sev-label">{{ sev_name }}</span>
        </div>
        {% endfor %}
    </div>
</div>

<!-- ── Findings ───────────────────────────────────────────────────────────── -->
<div class="section-heading">
    Findings
    <span class="total-badge">{{ findings | length }} total</span>
</div>

{% if not findings %}
<div class="card">
    <div class="no-findings">No findings were identified during this scan.</div>
</div>
{% else %}
{% for finding in findings %}
<div class="finding-card" style="border-left-color: {{ severity_colors[finding.severity.name] }};">
    <div class="finding-header">
        <span class="sev-badge" style="background: {{ severity_colors[finding.severity.name] }};">
            {{ finding.severity.name }}
        </span>
        <div class="finding-title-block">
            <div class="finding-title">{{ finding.title }}</div>
            <div class="finding-target">
                {{ finding.target }}{% if finding.port %}:{{ finding.port }}{% endif %}
            </div>
        </div>
    </div>

    <div class="field-group">
        <div class="field-label">Description</div>
        <div class="field-text">{{ finding.description }}</div>
    </div>

    {% if finding.evidence %}
    <div class="field-group">
        <div class="field-label">Evidence</div>
        <pre class="evidence-box">{{ finding.evidence }}</pre>
    </div>
    {% endif %}

    <div class="field-group">
        <div class="field-label">Remediation</div>
        <div class="remediation-box">{{ finding.remediation }}</div>
    </div>

    {% if finding.cve_ids %}
    <div class="field-group">
        <div class="field-label">CVE References</div>
        <div class="cve-list">
            {% for cve in finding.cve_ids %}
            <span class="cve-tag">{{ cve }}</span>
            {% endfor %}
        </div>
    </div>
    {% endif %}
</div>
{% endfor %}
{% endif %}

<!-- ── Footer ─────────────────────────────────────────────────────────────── -->
<div class="report-footer">
    <p class="footer-disclaimer">
        This report was produced by an automated security scanner. Findings have not been
        manually verified and may include false positives. All critical and high-severity
        findings should be reviewed and validated by a qualified security professional
        before remediation action is taken.
    </p>
    <div class="footer-timestamp">Generated {{ generated_at }} &mdash; secscan</div>
</div>

</div><!-- /.content -->
</body>
</html>
